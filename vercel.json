{
  "services": {
    "frontend": {
      "root": "frontend/",
      "framework": "vite",
      "outputDirectory": "dist"
    },
    "backend": {
      "root": "backend/",
      "entrypoint": "src/server.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}
